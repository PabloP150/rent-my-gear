# Nano Banana (Gemini) API key — required for on-demand image generation
NANO_BANANA_API_KEY=your_gemini_api_key_here

# Google Cloud Storage — optional. If unset, generated images are returned as data URLs.
GCS_BUCKET_NAME=rent-my-gear-images
GCS_PROJECT_ID=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=./gcs-key.json
